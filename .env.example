# ═══════════════════════════════════════════════════════════
# ArgusWatch AI v16.4.4 — Environment Configuration
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git — it contains your real API keys
# ═══════════════════════════════════════════════════════════

# ── DATABASE ──
POSTGRES_USER=arguswatch
POSTGRES_PASSWORD=arguswatch_dev_2026
POSTGRES_DB=arguswatch

# ── AUTH (change these in production!) ──
ADMIN_USER=admin
ADMIN_PASSWORD=arguswatch-admin-changeme
JWT_SECRET_KEY=change-this-to-a-random-64-char-string
AUTH_DISABLED=true

# ═══════════════════════════════════════════════════════════
# FREE TIER COLLECTORS (free API keys available)
# ═══════════════════════════════════════════════════════════

# AlienVault OTX — https://otx.alienvault.com (free signup)
OTX_API_KEY=

# VirusTotal — https://virustotal.com (free tier: 4 req/min)
VIRUSTOTAL_API_KEY=

# Shodan — https://shodan.io ($59 one-time for lifetime API)
SHODAN_API_KEY=

# Censys — https://censys.io (free tier available)
CENSYS_API_ID=
CENSYS_API_SECRET=

# GitHub Token — https://github.com/settings/tokens (free)
GITHUB_TOKEN=

# URLScan.io — https://urlscan.io (free tier)
URLSCAN_API_KEY=

# HIBP — https://haveibeenpwned.com/API/Key ($3.50/month)
HIBP_API_KEY=

# BreachDirectory — https://breachdirectory.org
BREACH_DIRECTORY_API_KEY=

# IntelX — https://intelx.io (free tier available)
INTELX_API_KEY=

# GreyNoise — https://greynoise.io (free community tier)
GREYNOISE_API_KEY=

# BinaryEdge — https://binaryedge.io (free tier)
BINARYEDGE_API_KEY=

# LeakIX — https://leakix.net (free tier)
LEAKIX_API_KEY=

# GrayHatWarfare — https://grayhatwarfare.com (free tier)
GRAYHATWARFARE_API_KEY=

# LeakCheck — https://leakcheck.io
LEAKCHECK_API_KEY=

# PhishTank — https://phishtank.org
PHISHTANK_API_KEY=

